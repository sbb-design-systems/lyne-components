{
  "name": "@sbb-esta/lyne-elements",
  "version": "5.0.0",
  "description": "Lyne Design System",
  "keywords": [
    "design system",
    "web components",
    "lit",
    "storybook"
  ],
  "author": "Lyne Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sbb-design-systems/lyne-components.git"
  },
  "bugs": {
    "url": "https://github.com/sbb-design-systems/lyne-components/issues"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "node -e \"!process.env.CI && child_process.spawn('yarn', ['playwright', 'install'], { stdio: 'inherit' })\"",
    "build": "node scripts/build.ts",
    "docs": "run-s docs:manifest docs:to-md",
    "docs:manifest": "run-s docs:manifest:*",
    "docs:manifest:elements": "custom-elements-manifest analyze --config tools/manifest/elements-custom-elements-manifest.config.ts",
    "docs:manifest:elements-experimental": "custom-elements-manifest analyze --config tools/manifest/elements-experimental-custom-elements-manifest.config.ts",
    "docs:to-md": "node tools/docs/docs_generate.ts",
    "format": "prettier \"**/*\" --write --ignore-unknown",
    "generate": "node tools/generate-component/index.ts",
    "integrity": "run-p format docs scss-api",
    "scss-api": "node scripts/generate-scss-api.ts",
    "lint": "run-s lint:*",
    "lint:ts": "eslint \"**/*.ts\"",
    "lint:js": "eslint \"**/*.js\"",
    "lint:yml": "eslint \"**/*.{yml,yaml}\"",
    "lint:styles": "stylelint \"**/*.scss\"",
    "lint:lit": "yarn lit-analyzer \"src/**/*.ts\"",
    "lint:circular-imports": "madge --circular --ts-config ./tsconfig.json --extensions ts ./src",
    "lint:tsc": "run-s lint:tsc:*",
    "lint:tsc:elements": "tsc --noEmit --project src/elements/tsconfig.json",
    "lint:tsc:elements-spec": "tsc --noEmit --project src/elements/tsconfig.spec.json",
    "lint:tsc:elements-experimental": "tsc --noEmit --project src/elements-experimental/tsconfig.json",
    "lint:tsc:elements-experimental-spec": "tsc --noEmit --project src/elements-experimental/tsconfig.spec.json",
    "lint:tsc:visual-regression-app": "tsc --noEmit --project src/visual-regression-app/tsconfig.json",
    "lint:tsc:scripts": "tsc --noEmit --project scripts/tsconfig.json",
    "lint:tsc:tools": "tsc --noEmit --project tools/tsconfig.json",
    "size-check": "node scripts/compare-stats.ts",
    "start": "storybook dev -p 6006",
    "start:visual-regression-app": "vite --config src/visual-regression-app/vite.config.ts",
    "test": "yarn -s wtr --coverage",
    "test:tsc": "run-s lint:tsc:*-spec",
    "test:snapshot": "yarn test:csr --ci --update-snapshots",
    "test:csr": "yarn -s wtr --group default",
    "test:visual-regression": "yarn -s wtr --visual-regression --all-browsers",
    "test:playwright-server": "node tools/web-test-runner/start-playwright-server.ts",
    "wtr": "node node_modules/@web/test-runner/dist/bin.js --config=web-test-runner.config.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@lit-labs/observers": "2.1.0",
    "lit": "3.3.3"
  },
  "optionalDependencies": {
    "@lit/react": "1.0.8",
    "tslib": "2.8.1",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@custom-elements-manifest/to-markdown": "0.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@inquirer/checkbox": "5.2.1",
    "@lit-labs/router": "0.1.4",
    "@lit-labs/testing": "0.2.8",
    "@open-wc/lit-helpers": "0.7.0",
    "@open-wc/testing": "4.0.0",
    "@sbb-esta/lyne-design-tokens": "2.1.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/icons": "2.1.0",
    "@storybook/web-components-vite": "10.4.6",
    "@tsdown/css": "0.22.3",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@web/test-runner": "0.20.2",
    "@web/test-runner-commands": "0.9.0",
    "@web/test-runner-playwright": "0.11.1",
    "@web/test-runner-visual-regression": "0.9.0",
    "cross-env": "10.1.0",
    "custom-elements-manifest": "2.1.0",
    "date-fns": "4.4.0",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-lit": "2.3.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-storybook": "10.4.6",
    "eslint-plugin-yml": "3.5.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "17.0.8",
    "lit-analyzer": "2.0.3",
    "madge": "8.0.0",
    "npm-run-all2": "9.0.2",
    "nyc": "18.0.0",
    "octokit": "5.0.5",
    "playwright": "1.61.1",
    "postcss": "8.5.16",
    "postcss-value-parser": "4.2.0",
    "prettier": "3.9.4",
    "remark-gfm": "^4.0.1",
    "sass-embedded": "1.100.0",
    "sinon": "22.0.0",
    "storybook": "10.4.6",
    "stylelint": "17.14.0",
    "stylelint-config-prettier-scss": "1.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-scss": "7.2.0",
    "temporal-polyfill": "1.0.1",
    "ts-lit-plugin": "2.0.2",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "urlpattern-polyfill": "10.1.0",
    "vite": "8.1.0",
    "vite-plugin-dts": "5.0.3"
  },
  "resolutions": {
    "@types/node": "24.13.2",
    "@webcomponents/template-shadowroot": "0.2.1",
    "@web/dev-server-core": "0.7.5",
    "lit": "3.3.3",
    "playwright": "1.61.1",
    "postcss": "8.5.16"
  },
  "prettier": {
    "singleQuote": true,
    "endOfLine": "lf",
    "printWidth": 100
  },
  "lint-staged": {
    "!(tools/generate-component/**/*)*.{js,ts,yaml,yml}": [
      "eslint --fix --no-ignore"
    ],
    "*.scss": [
      "stylelint --fix=true"
    ],
    "*.{js,ts,css,scss,json,md,html,yaml,yml}": [
      "prettier --write"
    ]
  },
  "madge": {
    "detectiveOptions": {
      "ts": {
        "skipTypeImports": true
      }
    }
  }
}
