{
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../dist/dev-infra-scripts",
    "module": "nodenext",
    "lib": ["esnext"],
    "skipLibCheck": true,
    "types": ["node"],
    "erasableSyntaxOnly": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["**/*.ts"],
  "exclude": ["generate-component", "../src/**/*.ts"]
}
