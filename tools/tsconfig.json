{
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../dist/dev-infra-scripts",
    "module": "nodenext",
    "lib": ["esnext"],
    "skipLibCheck": true,
    "types": ["node"],
    "erasableSyntaxOnly": true,
    "rewriteRelativeImportExtensions": true,
    "paths": {
      "aria-tree-type": ["../src/elements/core/testing/private/a11y-tree-snapshot.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["generate-component"]
}
